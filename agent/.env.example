# ===== XMTP =====
# Both values generated by the /generate-wallet page on the deployed web app.
# The wallet key IS the agent's identity. Never commit. Never share.
XMTP_WALLET_KEY=0xreplace_with_64_hex_chars
XMTP_DB_ENCRYPTION_KEY=replace_with_64_hex_chars

# XMTP network: "production" or "dev". Must match what the web app uses.
# SIGNA web is hardcoded to "production" — keep this matching.
XMTP_ENV=production

# Directory for the XMTP local SQLite DB. On Railway, mount a Volume at /data and set this to /data.
XMTP_DB_DIRECTORY=/data

# Optional: custom Base mainnet RPC URL for the agent's on-chain reads.
# Leave unset to use viem's default public RPC (rate-limited but usable).
# BASE_RPC_URL=https://mainnet.base.org

# Optional: custom Ethereum mainnet RPC URL for ENS reverse-lookups.
# ENS lives on mainnet, not Base.
# ETHEREUM_RPC_URL=https://cloudflare-eth.com

# ===== gitlawb =====
# The gitlawb_* tools resolve user queries into live deeplinks to
# gitlawb.com's public node browser. No DID or auth is required — the
# tools always work. Only override the base URL if you're pointing at a
# different gitlawb node (e.g. self-hosted).
# GITLAWB_BASE=https://gitlawb.com

# ===== MiroShark (optional, off by default) =====
# Base URL of your self-hosted MiroShark instance. When set, the
# miroshark_simulate tool POSTs to {URL}/api/simulation/create and
# returns the live /watch/<id> deeplink in chat. When unset, the tool
# returns deploy-your-own instructions + GitHub repo URL — never
# fabricates a sim result.
#
# Deploy your own: https://github.com/aaronjmars/MiroShark
# (Railway + Neo4j Aura + OpenRouter, ~3 min)
# MIROSHARK_BASE_URL=https://your-miroshark.up.railway.app

# ===== Groq =====
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Agent personality =====
AGENT_NAME=Vee
AGENT_SYSTEM_PROMPT=You are Vee, a friendly and curious agent who chats casually like a human friend. Keep replies short (1-3 sentences). Don't sound robotic. Don't introduce yourself unless asked.

# ===== Optional: autonomous greeting (for agent-to-agent chats) =====
# If set, the agent sends a greeting to this address on startup, then conversation continues organically.
# STARTUP_GREET_ADDRESS=0x...
# STARTUP_GREET_MESSAGE=hey, you up?

# ===== Multi-tenant runtime (npm run start:multi-runtime) =====
# Required ONLY when running the multi-tenant runtime (src/multi-runtime.ts)
# that picks up custodial agents opted in via signaagent.xyz/agent/<addr>/runtime.
# The single-tenant SIGNA central agent (src/index.ts) doesn't need these.
#
# Where SIGNA's API lives (must match the live web app):
# SIGNA_BASE_URL=https://www.signaagent.xyz
#
# Shared secret that lets this service fetch decrypted agent keys from
# /api/runtime/agents. Set the SAME value on Vercel env as
# RUNTIME_FETCH_SECRET. Rotate by changing both sides at once.
# RUNTIME_FETCH_SECRET=replace_with_32_hex_chars_or_more
#
# Poll cadence + cap:
# RUNTIME_POLL_INTERVAL_MS=30000
# RUNTIME_MAX_AGENTS=50
