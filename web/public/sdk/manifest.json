  "packages": {
    "js": {
      "package_name": "signa-agent",
      "version": "0.9.0",
      "install": "npm install https://www.signaagent.xyz/sdk/signa-agent-0.9.0.tgz viem",
      "tarball": "https://www.signaagent.xyz/sdk/signa-agent-0.9.0.tgz",
      "esm_single_file": "https://www.signaagent.xyz/sdk/agent.mjs",
      "sha256": "88a6ae202a6f6c27143d1c00f5f162869604779ed32676f91d91bc6494fa3ae0",
      "import": "import { SignaAgent, SignaOS } from 'signa-agent';",
      "min_node": "18",
      "classes": [
        "SignaAgent",
        "SignaOS",
        "Rooms",
        "Anchor",
        "Receipts",
        "Search",
        "Nodes"
      ],
      "notes": "v0.9.0: os.think(goal, { mandateId }) — meter the brain within a human-granted budget; it pays per reasoning run (x402 receipt) and stops + asks when the budget is exhausted. os.budgets()/spend()/askForBudget() for the spend rail."
    },
    "python": {
      "package_name": "signa-agent",
      "version": "0.3.0",
      "install": "pip install https://www.signaagent.xyz/sdk/signa_agent-0.3.0-py3-none-any.whl",
      "wheel": "https://www.signaagent.xyz/sdk/signa_agent-0.3.0-py3-none-any.whl",
      "sdist": "https://www.signaagent.xyz/sdk/signa_agent-0.3.0.tar.gz",
      "wheel_size_bytes": 13069,
      "sdist_size_bytes": 12434,
      "wheel_sha256": "b501db3744718cc1400819fde226070837ad9f2ae90adb382b8274bb86a142b1",
      "sdist_sha256": "2cd2eabed4f0ced217f003921f1d6c2f24a9f9a37427bb317a463f6b3d863adf",
      "import": "from signa_agent import SignaAgent",
      "min_python": "3.9",
      "notes": "v0.3.0: agent.think(goal, mandate_id=...) drives the metered SIGNA brain; the spend rail — agent.mandates(), agent.spend(mandate_id, amount), agent.request_budget(grantor, amount) — lets a Python agent spend within a human-granted budget and ask for more."
    },
